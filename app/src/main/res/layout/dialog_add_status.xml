<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@color/card_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新增状态"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="状态名称"
            android:textColorHint="#808080"
            app:boxBackgroundColor="#2A2A3A"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#404050"
            app:hintTextColor="#A0A0A0"
            app:errorEnabled="true"
            app:errorTextColor="#FF6B6B"
            app:layout_constraintTop_toBottomOf="@id/tv_dialog_title">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/white" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="状态描述（可选）"
            android:textColorHint="#808080"
            app:boxBackgroundColor="#2A2A3A"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#404050"
            app:hintTextColor="#A0A0A0"
            app:layout_constraintTop_toBottomOf="@id/til_name">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLines="2"
                android:textColor="@color/white" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tv_color_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="选择颜色"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/til_description" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_colors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxHeight="100dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_color_label" />

        <TextView
            android:id="@+id/tv_effect_type_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="效果类型"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_colors" />

        <RadioGroup
            android:id="@+id/rg_effect_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_effect_type_label">

            <RadioButton
                android:id="@+id/rb_periodic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="周期性变动"
                android:textColor="@color/white" />

            <RadioButton
                android:id="@+id/rb_bonus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="属性加成"
                android:textColor="@color/white" />

            <RadioButton
                android:id="@+id/rb_decay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="属性衰减"
                android:textColor="@color/white" />

        </RadioGroup>

        <TextView
            android:id="@+id/tv_target_attr_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="目标属性"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rg_effect_type" />

        <Spinner
            android:id="@+id/spinner_attribute"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/spinner_background"
            android:popupBackground="@color/card_dark"
            app:layout_constraintTop_toBottomOf="@id/tv_target_attr_label" />

        <LinearLayout
            android:id="@+id/ll_periodic_params"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/spinner_attribute">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周期设置"
                android:textColor="#A0A0A0"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_period_value"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/edit_text_background"
                    android:hint="周期值"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:text="1"
                    android:textColor="@color/white"
                    android:textColorHint="#808080" />

                <Spinner
                    android:id="@+id/spinner_period_unit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/spinner_background"
                    android:popupBackground="@color/card_dark" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="变动值（可正可负）"
                android:textColor="#A0A0A0"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_change_value"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:hint="如: -1 或 2.5"
                android:inputType="numberDecimal|numberSigned"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#808080" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_bonus_params"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/spinner_attribute">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加成百分比"
                android:textColor="#A0A0A0"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_bonus_percent"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:hint="如: 10 表示 +10%"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#808080" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_decay_params"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/spinner_attribute">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="衰减百分比"
                android:textColor="#A0A0A0"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_decay_percent"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:hint="如: 10 表示 -10%"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#808080" />

        </LinearLayout>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_params"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="ll_periodic_params,ll_bonus_params,ll_decay_params" />

        <TextView
            android:id="@+id/tv_duration_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="持续时间（可选，不设置表示永久）"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier_params" />

        <CheckBox
            android:id="@+id/cb_has_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="启用持续时间"
            android:textColor="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_duration_label" />

        <LinearLayout
            android:id="@+id/ll_duration_params"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cb_has_duration">

            <EditText
                android:id="@+id/et_duration_value"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/edit_text_background"
                android:hint="持续时间"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#808080" />

            <Spinner
                android:id="@+id/spinner_duration_unit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"
                android:popupBackground="@color/card_dark" />

        </LinearLayout>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="cb_has_duration,ll_duration_params" />

        <LinearLayout
            android:id="@+id/ll_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/barrier_duration">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#404040"
                android:text="取消"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="保存"
                android:textColor="@color/white" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
