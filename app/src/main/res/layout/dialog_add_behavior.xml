<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#2B2B36">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新增行为"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- 行为名称 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="行为名称(如:冥想)"
            app:hintTextColor="#A0A0A0"
            app:boxStrokeColor="#A0A0A0"
            android:textColorHint="#A0A0A0"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 精力变化类型 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="精力变化"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgEnergyType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbConsume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="消耗精力"
                android:textColor="@android:color/white"
                android:buttonTint="@android:color/white"
                android:checked="true"
                android:layout_marginEnd="24dp"/>

            <RadioButton
                android:id="@+id/rbRestore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="恢复精力"
                android:buttonTint="@android:color/white"
                android:textColor="@android:color/white" />
        </RadioGroup>

        <!-- 精力数值 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="精力数值"
            app:hintTextColor="#A0A0A0"
            app:boxStrokeColor="#A0A0A0"
            android:textColorHint="#A0A0A0"
            android:layout_marginTop="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEnergyValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:inputType="number"
                android:text="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 专注时长 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="专注时长(分钟，0表示即时完成)"
            app:hintTextColor="#A0A0A0"
            app:boxStrokeColor="#A0A0A0"
            android:textColorHint="#A0A0A0"
            android:layout_marginTop="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFocusDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:inputType="number"
                android:text="0" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 所属分组 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="所属分组"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/white"
            android:minHeight="48dp" />

        <!-- 影响的属性 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="影响的属性"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llAttributesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- 动态添加 item_behavior_attribute_modifier.xml -->
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddAttributeModifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ 添加影响的属性"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:strokeColor="#A0A0A0"
            app:strokeWidth="1dp"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp" />

        <!-- 底部操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="取消"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#A0A0A0"
                android:textColor="#A0A0A0"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="确定"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>