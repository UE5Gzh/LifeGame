<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#2B2B36">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新增任务"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="任务名称"
            app:hintTextColor="#A0A0A0"
            app:boxStrokeColor="#A0A0A0"
            android:textColorHint="#A0A0A0"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="任务类型"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日常"
                android:textColor="@android:color/white"
                android:buttonTint="@android:color/white"
                android:checked="true"
                android:layout_marginEnd="16dp"/>

            <RadioButton
                android:id="@+id/rbMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="主线"
                android:buttonTint="@android:color/white"
                android:layout_marginEnd="16dp"
                android:textColor="@android:color/white" />

            <RadioButton
                android:id="@+id/rbSide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="支线"
                android:buttonTint="@android:color/white"
                android:textColor="@android:color/white" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvDeadlineLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="截止日期"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvDeadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择日期"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:padding="12dp"
            android:background="@drawable/bg_progress_energy"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="完成目标"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llGoalsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddAttrGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ 属性目标"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:strokeColor="#A0A0A0"
                app:strokeWidth="1dp"
                android:textColor="@android:color/white"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddBehGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ 行动目标"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:strokeColor="#A0A0A0"
                app:strokeWidth="1dp"
                android:textColor="@android:color/white"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="任务奖励"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llRewardsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddReward"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ 添加奖励"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:strokeColor="#A0A0A0"
            app:strokeWidth="1dp"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="任务惩罚 (可选)"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llPunishmentsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddPunishment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ 添加惩罚"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:strokeColor="#A0A0A0"
            app:strokeWidth="1dp"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp" />

        <!-- Bottom Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="取消"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#A0A0A0"
                android:textColor="#A0A0A0"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="确定"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>